{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user settings and companion information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "companion": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "characterId": { "type": "string" },
            "size": { "type": "number" },
            "level": { "type": "number" },
            "experience": { "type": "number" }
          }
        },
        "settings": {
          "type": "object",
          "properties": {
            "notificationsEnabled": { "type": "boolean" },
            "theme": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ChatSession": {
      "title": "Chat History",
      "description": "Stores chat logs between user and companion",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string" },
              "content": { "type": "string" },
              "timestamp": { "type": "number" }
            }
          }
        }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and companion state"
    },
    "/chats/{chatId}": {
      "schema": "ChatSession",
      "description": "Historical chat logs"
    }
  }
}
